[
  {
    "name": "WeeklyDigest",
    "scriptFile": "WeeklyDigest.dll",
    "entryPoint": "WeeklyDigest.Functions.WeeklyDigestFunction.Run",
    "language": "dotnet-isolated",
    "properties": {
      "IsCodeless": false
    },
    "bindings": [
      {
        "name": "timer",
        "direction": "In",
        "type": "timerTrigger",
        "schedule": "0 0 8 * * 1",
        "properties": {}
      }
    ]
  }
]